{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useTemplate": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 100
	},
	"files": {
		"includes": ["**", "!dist", "!coverage", "!node_modules"]
	}
}
